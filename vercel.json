{
  "buildCommand": "npx prisma generate && npx prisma db push --accept-data-loss && next build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/sync-stations",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/price-alerts",
      "schedule": "0 9 * * *"
    }
  ]
}

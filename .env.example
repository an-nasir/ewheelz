# ─── Neon (free PostgreSQL) ───────────────────────────────────────────────────
# Sign up at https://neon.tech → create a project → copy the connection strings
#
# Pooled URL  → used by Prisma at runtime (serverless-safe)
DATABASE_URL="postgresql://<user>:<password>@<host>.neon.tech/<dbname>?sslmode=require&pgbouncer=true&connect_timeout=15"

# Direct URL → used by Prisma migrations / db push (bypasses PgBouncer)
DIRECT_URL="postgresql://<user>:<password>@<host>.neon.tech/<dbname>?sslmode=require"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Mapbox (charging station map) ───────────────────────────────────────────
# Get a free token at https://mapbox.com
NEXT_PUBLIC_MAPBOX_TOKEN=""

# ─── OpenChargeMap (live charger data) ────────────────────────────────────────
# Free API key at https://openchargemap.org/site/develop
OPENCHARGEMMAP_API_KEY=""

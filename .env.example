# ─── Neon (free PostgreSQL) ───────────────────────────────────────────────────
# Sign up at https://neon.tech → create a project → copy the connection strings
#
# Pooled URL  → used by Prisma at runtime (serverless-safe)
DATABASE_URL="postgresql://<user>:<password>@<host>.neon.tech/<dbname>?sslmode=require&pgbouncer=true&connect_timeout=15"

# Direct URL → used by Prisma migrations / db push (bypasses PgBouncer)
DIRECT_URL="postgresql://<user>:<password>@<host>.neon.tech/<dbname>?sslmode=require"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Mapbox (charging station map) ───────────────────────────────────────────
# Get a free token at https://mapbox.com
NEXT_PUBLIC_MAPBOX_TOKEN=""

# ─── OpenChargeMap (live charger data) ────────────────────────────────────────
# Free API key at https://openchargemap.org/site/develop
OPENCHARGEMMAP_API_KEY=""

# ─── Analytics ────────────────────────────────────────────────────────────────
# Google Analytics 4 — get Measurement ID from GA4 → Admin → Data Streams
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Mixpanel — get token from mixpanel.com → Project Settings → Project Token
NEXT_PUBLIC_MIXPANEL_TOKEN=""

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# Free tier: 3,000 emails/month. Sign up at https://resend.com
# Requires a verified sending domain for production.
RESEND_API_KEY=""

# The "From" address shown in outbound emails.  Must match your verified domain.
RESEND_FROM_EMAIL="eWheelz <hello@ewheelz.pk>"

# ─── Lead Notifications ────────────────────────────────────────────────────────
# Where new dealer-enquiry leads are emailed (admin/sales inbox)
LEAD_NOTIFICATION_EMAIL="leads@ewheelz.pk"

# ─── Cron Security ────────────────────────────────────────────────────────────
# Random secret to protect /api/cron/* endpoints. Vercel sends this automatically.
# Generate with: openssl rand -hex 32
CRON_SECRET=""

# ─── WhatsApp ──────────────────────────────────────────────────────────────────
# Pakistani number in international format WITHOUT the + sign e.g. 923001234567
NEXT_PUBLIC_WHATSAPP_NUMBER="923001234567"

# WhatsApp community/group invite link (from WhatsApp → Group → Invite via Link)
NEXT_PUBLIC_WA_GROUP_URL="https://chat.whatsapp.com/your-invite-link"

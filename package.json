    "poll-stations": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/poll_stations.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@next/third-parties": "^16.2.1",

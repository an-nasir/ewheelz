    "@types/bcryptjs": "^2.4.6",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "idb": "^8.0.3",
    "mixpanel-browser": "^2.77.0",
    "next": "^14.2.0",
    "next-auth": "^4.24.13",
    "next-intl": "^4.8.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "resend": "^6.9.4",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
